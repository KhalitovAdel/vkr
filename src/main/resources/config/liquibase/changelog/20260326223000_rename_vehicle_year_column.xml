<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260326223000-1" author="adelkhalitov">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="vehicle"/>
                <columnExists tableName="vehicle" columnName="year"/>
                <not>
                    <columnExists tableName="vehicle" columnName="manufacture_year"/>
                </not>
            </and>
        </preConditions>

        <renameColumn
            tableName="vehicle"
            oldColumnName="year"
            newColumnName="manufacture_year"
            columnDataType="int"/>
    </changeSet>
</databaseChangeLog>
